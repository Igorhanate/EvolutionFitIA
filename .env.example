# =============================================================
# VARIÁVEIS DE AMBIENTE — EvolutionFit IA
# Copie este arquivo para .env e preencha os valores reais.
#
# No Railway, adicione estas variáveis em:
#   Project → Service → Variables
#
# Variáveis marcadas com [Railway: automático] são injetadas
# automaticamente quando você adiciona o plugin PostgreSQL.
# =============================================================

# --- BANCO DE DADOS ---
# [Railway: automático] O Railway injeta DATABASE_URL ao provisionar PostgreSQL.
# Localmente use o formato abaixo:
DATABASE_URL=postgresql://postgres:password@localhost:5432/evolutionfit

# --- ANTHROPIC (Claude AI) ---
ANTHROPIC_API_KEY=sk-ant-...

# --- EVOLUTION API (WhatsApp) ---
# URL pública da sua instância Evolution API (ex: Railway, VPS, ngrok)
EVOLUTION_API_URL=https://sua-instancia-evolution.up.railway.app
EVOLUTION_API_TOKEN=evfit_secret_key_2026
EVOLUTION_API_INSTANCE=evolutionfit

# --- HOTMART ---
HOTMART_WEBHOOK_SECRET=seu-secret-hotmart
HOTMART_OFFER_ID_TRIMESTRAL=CODIGO_OFERTA_TRIMESTRAL
HOTMART_OFFER_ID_ANUAL=CODIGO_OFERTA_ANUAL

# --- LINKS DE PAGAMENTO ---
PAYMENT_LINK_TRIMESTRAL=https://pay.hotmart.com/SEU_PRODUTO?off=OFERTA_TRIMESTRAL
PAYMENT_LINK_ANUAL=https://pay.hotmart.com/SEU_PRODUTO?off=OFERTA_ANUAL
